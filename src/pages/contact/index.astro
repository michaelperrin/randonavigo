---
import BaseLayout from "~/layouts/BaseLayout.astro";
import TopBanner from "~/components/TopBanner.astro";
---

<BaseLayout
  title="Contact — RandoNavigo"
  description="Contactez RandoNavigo pour toute question, suggestion ou partenariat."
>
  <TopBanner overlay={true}>
    <h1 class="text-3xl md:text-5xl font-condensed font-medium">Contact</h1>
    <p class="mt-2 text-lg md:text-xl">
      Une question, une suggestion&nbsp;? N'hésitez pas&nbsp;!
    </p>
  </TopBanner>

  <article class="container mx-auto max-w-2xl py-16 px-4">
    <section>
      <p class="text-lg text-gray-700 mb-8">
        Vous pouvez me contacter via le formulaire ci-dessous. Je ferai de mon
        mieux pour vous répondre rapidement.
      </p>

      <div class="mb-16">
        <iframe
          data-tally-src="https://tally.so/embed/pbBa6P?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
          loading="lazy"
          width="100%"
          height="313"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          title="Contact RandoNavigo"></iframe>
      </div>
    </section>

    <section class="border-t border-gray-200 pt-10">
      <h2 class="text-2xl font-condensed font-medium mb-6">
        Retrouvez-moi sur les réseaux
      </h2>

      <div class="flex flex-col gap-5">
        <a
          href="https://www.instagram.com/randonavigo"
          target="_blank"
          rel="noreferrer"
          class="flex items-center gap-4 p-4 rounded-lg border border-gray-200 hover:border-gray-300 hover:bg-gray-50 transition-colors"
        >
          <img
            src="/images/social/instagram.svg"
            alt="Instagram"
            class="w-8 h-8"
          />
          <div>
            <div class="font-medium">Instagram</div>
            <p class="text-sm text-gray-600">
              Suivez les actualités de RandoNavigo et découvrez les dernières
              randonnées en images.
            </p>
          </div>
        </a>

        <a
          href="https://www.linkedin.com/in/perrinmichael/"
          target="_blank"
          rel="noreferrer"
          class="flex items-center gap-4 p-4 rounded-lg border border-gray-200 hover:border-gray-300 hover:bg-gray-50 transition-colors"
        >
          <img
            src="/images/social/linkedin.svg"
            alt="LinkedIn"
            class="w-8 h-8"
          />
          <div>
            <div class="font-medium">LinkedIn</div>
            <p class="text-sm text-gray-600">
              Retrouvez mon profil professionnel sur LinkedIn.
            </p>
          </div>
        </a>
      </div>
    </section>
  </article>
</BaseLayout>

<script is:inline>
  var d=document,w="https://tally.so/widgets/embed.js",v=function(){"undefined"!=typeof Tally?Tally.loadEmbeds():d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach(function(e){e.src=e.dataset.tallySrc})};if("undefined"!=typeof Tally)v();else if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w,s.onload=v,s.onerror=v,d.body.appendChild(s);}
</script>
