---
import { SITE_TITLE, SITE_DESCRIPTION } from "~/consts";
import BaseLayout from "~/layouts/BaseLayout.astro";
import HomeIntro from "~/components/Home/HomeIntro.astro";
import HowItWorks from "~/components/Home/HowItWorks.astro";
import ThemeSections from "~/components/Home/ThemeSections.astro";
import AboutTeaser from "~/components/Home/AboutTeaser.astro";
import Testimonials from "~/components/Home/Testimonials.astro";
import TopBanner from "~/components/TopBanner.astro";
import banner from "~/assets/home-bg.jpeg";
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} image={banner}>
  <TopBanner overlay={true} overlayVariant="hero">
    <h1 class="text-2xl md:text-3xl lg:text-4xl font-condensed font-medium leading-snug tracking-tight max-w-2xl">
      Évadez-vous en pleine nature en Île-de-France
    </h1>
    <p class="mt-4 text-base md:text-lg text-white/95 max-w-xl leading-relaxed">
      Pas besoin de voiture&nbsp;: votre carte Navigo suffit pour partir
      randonner.
    </p>
    <a href="/randonnees/" class="hero-cta">
      Découvrir les randonnées
    </a>
  </TopBanner>

  <style>
    .hero-cta {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-top: 2rem;
      padding: 0.75rem 2rem;
      font-family: var(--font-sans-serif);
      font-size: 0.875rem;
      font-weight: 600;
      letter-spacing: 0.025em;
      text-decoration: none;
      color: #fff;
      text-shadow: none;
      border-radius: 9999px;
      border: 2px solid rgba(255, 255, 255, 0.55);
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      box-shadow: none;
      transition: border-color 0.2s ease;
    }

    .hero-cta::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background: rgba(255, 255, 255, 0);
      transition: background 0.2s ease;
      pointer-events: none;
    }

    .hero-cta:hover {
      border-color: rgba(255, 255, 255, 0.88);
      box-shadow: none;
      text-shadow: none;
    }

    .hero-cta:hover::before {
      background: rgba(255, 255, 255, 0.2);
    }
  </style>

  <HomeIntro />

  <HowItWorks />

  <ThemeSections />

  <AboutTeaser />

  <Testimonials />
</BaseLayout>
