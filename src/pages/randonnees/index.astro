---
import BaseLayout from "~/layouts/BaseLayout.astro";
import List from "~/components/Hike/List.astro";
import TopBanner from "~/components/TopBanner.astro";
import { getHikesSorted } from "~/lib/getHikes";
import ThemeFilterNav from "~/components/Theme/ThemeFilterNav.astro";

const hikes = await getHikesSorted();
---

<BaseLayout
  title="Toutes les randonnées — RandoNavigo"
  description="Retrouvez toutes les randonnées en Île-de-France accessibles en transport en commun : forêt, bord de l'eau, patrimoine et campagne."
>
  <TopBanner overlay={true}>
    <h1
      class="font-condensed text-2xl font-bold tracking-tight md:text-4xl"
      style={{ textShadow: "0 1px 16px rgba(0,0,0,0.35)" }}
    >
      Toutes les randonnées
    </h1>
    <p class="mt-3 max-w-xl text-base text-white/90 md:text-lg">
      {hikes.length} randonnées en Île-de-France, toutes accessibles en
      transport en commun.
    </p>
  </TopBanner>

  <section class="py-14 md:py-16">
    <div class="container mx-auto px-4">
      {/* Rangée de filtre — d'autres suivront (difficulté, lignes…) sur le même modèle */}
      <div class="mb-10 md:mb-12">
        <ThemeFilterNav />
      </div>
    </div>

    <List hikes={hikes} />
  </section>
</BaseLayout>
