---
import { Image } from "astro:assets";
import { type CollectionEntry } from "astro:content";
import { getHikeImage, getHikeImagePath } from "~/lib/getHikeImage";
import { getHikeUrl } from "~/lib/getHikeUrl";
import TransportPoint from "~/components/transport/TransportPoint.astro";
import { themes, type ThemeKey } from "~/data/themes";

const { hike } = Astro.props;

const hikeThemes = ((hike.data.themes ?? []) as ThemeKey[]).map(
  (key) => themes[key]
);

const getHikeImageUrl = (hike: CollectionEntry<"hike">) => {
  return getHikeImage(
    getHikeImagePath(hike.data.pubDate, hike.data.slug, hike.data.main_picture)
  );
};

const imageUrl = getHikeImageUrl(hike);

const hikeData = hike.data;
---

<article
  class="flex flex-col mb-4 bg-white shadow-card"
  data-hike-distance={hikeData.distance}
>
  <a
    href={getHikeUrl(hike)}
    class="h-64 md:h-48 xl:h-64 block flex-none relative"
  >
    <div class="relative h-full">
      {
        hikeData.favorite && (
          <div class="absolute top-0 right-0 z-10">
            <Image
              src="/images/favorite.svg"
              alt="Randonnée favorite"
              width={48}
              height={48}
            />
          </div>
        )
      }

      {
        imageUrl && (
          <Image
            width={720}
            height={600}
            src={imageUrl}
            alt=""
            class="w-full h-full object-cover"
          />
        )
      }

      {
        hikeThemes.length > 0 && (
          <div class="absolute bottom-2.5 left-2.5 z-10 flex items-center gap-2 rounded-full bg-black/30 px-2.5 py-1.5 text-white shadow-sm ring-1 ring-white/30 backdrop-blur-md">
            {hikeThemes.map((theme) => (
              <span
                class="flex items-center justify-center"
                title={theme.label}
              >
                <svg
                  class="h-4 w-4"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={theme.icon}
                />
                <span class="sr-only">{theme.label}</span>
              </span>
            ))}
          </div>
        )
      }
    </div>
  </a>

  <div class="flex flex-col flex-1 mx-4 mt-4">
    <div>
      <div class="mt-2 mb-4">
        {
          hikeData.categories && hikeData.categories.length >= 0 && (
            <div
              class="uppercase text-xs text-gray-500 text-center leading-none mb-1"
              style={{ color: "#4e6c85" }}
            >
              {/* Only display first category */}
              {hikeData.categories[0]}
            </div>
          )
        }

        <h2
          class="font-sans-serif text-lg font-semibold text-center mx-8 leading-snug"
        >
          <a href={getHikeUrl(hike)}>{hikeData.title}</a>
        </h2>
      </div>

      <div
        class="text-justify text-zinc-600 mt-2 mb-4 font-serif"
        style={{ fontSize: "15px", hyphens: "auto" }}
      >
        {hikeData.description}
      </div>
    </div>

    <div class="flex items-center mt-auto mb-3 pt-3 border-t border-gray-200">
      <div class="flex-grow-1 text-sm items-center font-sans-serif">
        <TransportPoint
          line={hikeData.starting_point.line}
          station={hikeData.starting_point.station}
          iconSize={20}
        />
      </div>

      <div
        class="shrink-0 flex ml-auto font-sans-serif text-sm font-medium gap-1"
      >
        <div>
          <Image
            src="/images/hike-icon.svg"
            alt="Distance de marche"
            width={14}
            height={14}
          />
        </div>
        <div>
          {hikeData.distance}
          km
        </div>
      </div>
    </div>
  </div>
</article>
