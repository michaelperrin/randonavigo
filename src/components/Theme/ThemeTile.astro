---
import { Image } from "astro:assets";
import type { ThemeData } from "~/lib/getThemesData";

interface Props {
  theme: ThemeData;
  /** Classes de format (ratio) de la tuile */
  class?: string;
}

const { theme, class: aspectClasses = "aspect-[16/9] sm:aspect-[3/4]" } =
  Astro.props;
---

<a
  href={`/randonnees/${theme.config.slug}/`}
  class:list={[
    "group relative block overflow-hidden rounded-2xl shadow-sm",
    aspectClasses,
  ]}
  aria-label={`Voir les ${theme.total} randonnées « ${theme.config.label} »`}
>
  {
    theme.coverImage && (
      <Image
        src={theme.coverImage}
        alt=""
        width={800}
        height={1000}
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      />
    )
  }
  {/* Dégradé sombre bas → haut pour la lisibilité, sans teinter la photo */}
  <div
    class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/30 to-transparent"
    aria-hidden="true"
  />

  <div class="absolute inset-x-0 bottom-0 p-4 text-white md:p-5">
    <div class="mb-1.5 flex items-center gap-2">
      <span
        class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-white"
        style={{ backgroundColor: theme.config.accent }}
        aria-hidden="true"
      >
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.7"
          stroke-linecap="round"
          stroke-linejoin="round"
          set:html={theme.config.icon}
        />
      </span>
      <h3
        class="font-condensed text-2xl font-black tracking-tight md:text-3xl"
      >
        {theme.config.label}
      </h3>
    </div>
    <p class="line-clamp-2 text-sm leading-snug text-white/85">
      {theme.config.description}
    </p>
    <span
      class="mt-3 inline-flex items-center gap-1.5 whitespace-nowrap rounded-full border border-white/35 bg-white/15 px-3.5 py-1.5 text-sm font-semibold backdrop-blur-sm transition group-hover:bg-white/25"
    >
      {theme.total} randonnées
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="transition-transform group-hover:translate-x-0.5"
        aria-hidden="true"
      >
        <path d="M5 12h14" />
        <path d="m12 5 7 7-7 7" />
      </svg>
    </span>
  </div>
</a>
