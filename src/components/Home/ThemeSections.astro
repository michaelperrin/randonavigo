---
import HikeCard from "~/components/Hike/HikeCard.astro";
import ThemeTile from "~/components/Theme/ThemeTile.astro";
import { getHikesSorted } from "~/lib/getHikes";
import { getThemesData } from "~/lib/getThemesData";

const themesData = await getThemesData();
const latestHikes = (await getHikesSorted()).slice(0, 6);
---

<section
  class="bg-white py-14 md:py-16"
  aria-labelledby="randonnees-themes-heading"
>
  <div class="container mx-auto px-4">
    <div class="mx-auto mb-10 max-w-2xl text-center md:mb-12">
      <p
        class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-stone-500"
      >
        Parcourir par ambiance
      </p>
      <h2
        id="randonnees-themes-heading"
        class="font-condensed mb-4 text-2xl font-bold tracking-tight text-zinc-900 md:text-3xl"
      >
        Choisissez votre ambiance
      </h2>
      <p class="text-sm leading-relaxed text-stone-600 md:text-base">
        Au bord de l’eau, en forêt, à travers champs ou au fil du
        patrimoine&nbsp;: chaque thème regroupe toutes les randonnées qui lui
        correspondent.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:gap-5 lg:grid-cols-4">
      {themesData.map((theme) => <ThemeTile theme={theme} />)}
    </div>
  </div>
</section>

<section
  class="border-y border-stone-200 bg-stone-50 py-14 md:py-16"
  aria-labelledby="dernieres-randonnees-heading"
>
  <div class="container mx-auto px-4">
    <div class="mx-auto mb-10 max-w-2xl text-center md:mb-12">
      <p
        class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-stone-500"
      >
        Fraîchement publiées
      </p>
      <h2
        id="dernieres-randonnees-heading"
        class="font-condensed mb-4 text-2xl font-bold tracking-tight text-zinc-900 md:text-3xl"
      >
        Les dernières randonnées
      </h2>
      <p class="text-sm leading-relaxed text-stone-600 md:text-base">
        Ouvrez une fiche pour le parcours détaillé, la trace GPX et les accès
        en transports.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {latestHikes.map((hike) => <HikeCard hike={hike} />)}
    </div>

    <div class="mt-12 text-center">
      <a
        href="/randonnees/"
        class="inline-flex items-center gap-2 rounded-lg bg-zinc-900 px-7 py-3.5 text-sm font-bold text-white shadow-sm transition hover:bg-zinc-800"
      >
        Toutes les randonnées
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14" />
          <path d="m12 5 7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
