---
import HikeCard from "~/components/Hike/HikeCard.astro";
import { themes, themeKeys } from "~/data/themes";
import { getHikesForTheme } from "~/lib/getHikes";

const themesData = await Promise.all(
  themeKeys.map(async (key) => {
    const hikes = await getHikesForTheme(key);
    return {
      key,
      config: themes[key],
      hikes: hikes.slice(0, 3),
      total: hikes.length,
    };
  }),
);
---

<section
  class="border-t border-zinc-200 bg-white pt-12 md:pt-16 pb-6 md:pb-8"
  aria-labelledby="randonnees-themes-heading"
>
  <div class="container mx-auto px-4">
    <div class="mx-auto max-w-2xl text-center">
      <p
        class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-stone-500"
      >
        Parcourir
      </p>
      <h2
        id="randonnees-themes-heading"
        class="font-condensed mb-4 text-2xl font-bold tracking-tight text-zinc-900 md:text-3xl"
      >
        Les randonnées par thème
      </h2>
      <div
        class="mx-auto mb-6 h-1 w-14 rounded-full bg-zinc-900"
        aria-hidden="true"
      />
      <p class="text-sm leading-relaxed text-stone-600 md:text-base">
        Eau, forêt, paysage champêtre ou patrimoine : parcourez les idées par
        ambiance, puis ouvrez une fiche pour la trace GPX et les accès en
        transports.
      </p>
    </div>
  </div>
</section>

{
  themesData.map((theme, i) => (
    <section
      class:list={[
        i === 0 ? "pt-6 pb-14 md:pt-8 md:pb-16" : "py-14 md:py-16",
        i % 2 === 1 ? "bg-zinc-50" : "bg-white",
      ]}
    >
      <div class="container mx-auto px-4">
        <div class="mb-3 flex items-start gap-3 md:gap-4">
          <span
            class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full md:mt-2.5 md:h-3 md:w-3"
            style={{ backgroundColor: theme.config.accent }}
            aria-hidden="true"
          />
          <div class="min-w-0 flex-1">
            <h3 class="font-condensed text-3xl font-black tracking-tight text-zinc-900 md:text-4xl">
              {theme.config.label}
            </h3>
            <div
              class="mt-3 h-1 max-w-full w-16 rounded-full"
              style={{ backgroundColor: theme.config.accent }}
              aria-hidden="true"
            />
          </div>
        </div>

        <p class="mb-8 max-w-3xl text-sm leading-relaxed text-stone-600 md:mb-10 md:text-base">
          {theme.config.description}
        </p>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {theme.hikes.map((hike) => (
            <HikeCard hike={hike} />
          ))}
        </div>

        <div class="mt-10 text-center">
          <a
            href={`/randonnees/${theme.config.slug}/`}
            class="inline-flex items-center gap-2 rounded-lg px-6 py-3 text-sm font-bold text-white shadow-sm transition hover:brightness-110 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            style={{
              backgroundColor: theme.config.accent,
              outlineColor: theme.config.accent,
            }}
          >
            Voir les {theme.total} randonnées «&nbsp;{theme.config.label}&nbsp;»
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  ))
}

<section
  class="border-t border-zinc-200 bg-white py-14 md:py-16"
  aria-label="Accès au catalogue complet"
>
  <div class="container mx-auto px-4 text-center">
    <a
      href="/randonnees/"
      class="inline-flex items-center gap-2 rounded-lg bg-zinc-900 px-7 py-3.5 text-sm font-bold text-white shadow-sm transition hover:bg-zinc-800"
    >
      Toutes les randonnées
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M5 12h14" />
        <path d="m12 5 7 7-7 7" />
      </svg>
    </a>
  </div>
</section>
