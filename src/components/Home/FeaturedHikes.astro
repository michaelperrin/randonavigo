---
import type { CollectionEntry } from "astro:content";
import HikeCard from "~/components/Hike/HikeCard.astro";
import { getHikesSorted } from "~/lib/getHikes";

const allHikes = await getHikesSorted();
const featured = allHikes.filter((h: CollectionEntry<"hike">) => h.data.favorite).slice(0, 3);
---

<section class="bg-zinc-50 py-14 md:py-16">
  <div class="container mx-auto px-4">
    <div class="text-center mb-10 md:mb-12">
      <h2 class="font-condensed text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 mb-3">
        Coups de cœur
      </h2>
      <p class="text-stone-600 text-sm md:text-base max-w-xl mx-auto leading-relaxed">
        Parmi les plus belles randonnées que j'ai faites en Île-de-France.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 max-w-5xl mx-auto">
      {featured.map((hike: CollectionEntry<"hike">) => <HikeCard hike={hike} />)}
    </div>

    <div class="mt-10 flex justify-center">
      <a
        href="#toutes-les-randonnees"
        class="group inline-flex items-center gap-2 text-sm font-medium text-sky-800 no-underline border-b border-sky-800/25 pb-0.5 transition-colors hover:border-sky-800 hover:text-sky-900"
      >
        <span>Voir toutes les randonnées</span>
        <svg
          class="w-4 h-4 shrink-0 transition-transform group-hover:translate-x-0.5"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
