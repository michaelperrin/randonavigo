---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { getArticleImage } from "~/lib/getArticleImage";

interface Props {
  article: CollectionEntry<"article">;
}

const { article } = Astro.props;
const { title, description, pubDate, slug, thumbnail } = article.data;
const imageUrl = getArticleImage(slug, thumbnail);
const dateFormatted = pubDate.toLocaleDateString("fr-FR", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
const href = `/actualites/${article.id}`;
---

<article class="flex flex-col sm:flex-row gap-6 sm:gap-8 py-8 border-b border-zinc-200 last:border-b-0">
  <a
    href={href}
    class="block shrink-0 w-full sm:w-56 md:w-64 aspect-[4/3] overflow-hidden"
  >
    {
      imageUrl && (
        <Image
          width={640}
          height={480}
          src={imageUrl}
          alt={title}
          class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
        />
      )
    }
  </a>

  <div class="flex flex-col flex-1 min-w-0">
    <div class="text-xs text-zinc-500 font-condensed uppercase tracking-wide">
      {dateFormatted}
    </div>
    <h2 class="font-condensed text-2xl md:text-3xl font-medium mt-1 mb-3 leading-tight">
      <a
        href={href}
        class="text-zinc-900 hover:text-zinc-600 transition-colors"
      >
        {title}
      </a>
    </h2>
    <p class="text-zinc-600 font-serif leading-relaxed">
      {description}
    </p>
    <a
      href={href}
      class="mt-4 inline-block text-sm font-condensed uppercase tracking-wide text-zinc-700 hover:text-zinc-900 self-start"
    >
      Lire la suite →
    </a>
  </div>
</article>
