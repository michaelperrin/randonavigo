---
import { Image } from "astro:assets";
import banner from "~/assets/home-bg.jpeg";

type OverlayVariant = "default" | "hero";

const {
  picture = banner,
  video,
  overlay = false,
  overlayVariant = "default",
} = Astro.props as {
  picture?: typeof banner;
  video?: string;
  overlay?: boolean;
  overlayVariant?: OverlayVariant;
};

const overlayClasses = overlay
  ? overlayVariant === "hero"
    ? "after:absolute after:inset-0 after:z-20 after:bg-[linear-gradient(180deg,rgba(0,0,0,0)_0%,rgba(0,0,0,0.22)_40%,rgba(0,0,0,0.58)_100%)]"
    : "after:absolute after:inset-0 after:bg-linear-to-b after:from-transparent after:via-transparent after:to-black after:z-20 after:opacity-70"
  : "";

const contentClasses =
  overlayVariant === "hero"
    ? "pt-28 md:pt-32 pb-10 md:pb-14 px-4 max-w-3xl mx-auto text-center z-30 text-white flex flex-col items-center"
    : "pt-32 px-4 md:px-48 z-30 text-white";
---

<div
  class="relative flex min-h-[35vh] md:min-h-[80vh] flex-col align-middle justify-center overflow-hidden bg-black"
>
  <div
    class={contentClasses}
    style={{
      fontFamily: "Barlow",
      textShadow:
        overlayVariant === "hero"
          ? "0 1px 16px rgba(0, 0, 0, 0.35)"
          : "0 0 40px rgba(0, 0, 0, 0.9)",
    }}
  >
    <slot />
  </div>

  <div class={overlayClasses}>
    {video ? (
      <video
        src={video}
        autoplay
        muted
        loop
        playsinline
        class="w-full h-full object-cover absolute top-0 left-0"
      />
    ) : (
      <div class="banner-image-reveal absolute top-0 left-0 h-full w-full">
        <Image
          src={picture}
          alt=""
          width={1920}
          height={1080}
          class="w-full h-full object-cover"
        />
      </div>
    )}
  </div>

  {!video && (
    <div class="banner-reveal-veil absolute inset-0 z-10 bg-black pointer-events-none" />
  )}
</div>

<style>
  @keyframes banner-zoom {
    from {
      transform: scale(1.05);
    }
    to {
      transform: scale(1);
    }
  }

  @keyframes banner-veil-fade {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  .banner-image-reveal {
    animation: banner-zoom 1.5s ease both;
    transform-origin: center;
    will-change: transform;
  }

  .banner-reveal-veil {
    animation: banner-veil-fade 1.5s ease both;
  }

  @media (prefers-reduced-motion: reduce) {
    .banner-image-reveal,
    .banner-reveal-veil {
      animation: none;
    }
    .banner-reveal-veil {
      opacity: 0;
    }
  }
</style>
