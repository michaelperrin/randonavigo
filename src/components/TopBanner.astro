---
import { Image } from "astro:assets";
import banner from "~/assets/home-bg.jpeg";

type OverlayVariant = "default" | "hero";

const {
  picture = banner,
  video,
  overlay = false,
  overlayVariant = "default",
} = Astro.props as {
  picture?: typeof banner;
  video?: string;
  overlay?: boolean;
  overlayVariant?: OverlayVariant;
};

const overlayKind = overlay
  ? overlayVariant === "hero"
    ? video
      ? "hero-video"
      : "hero-image"
    : "default"
  : null;

const contentClasses =
  overlayVariant === "hero"
    ? "pt-28 md:pt-32 pb-10 md:pb-14 px-4 max-w-3xl mx-auto text-center z-30 text-white flex flex-col items-center"
    : "pt-32 px-4 md:px-48 z-30 text-white";
---

<div
  class="relative flex min-h-[35vh] md:min-h-[80vh] flex-col align-middle justify-center overflow-hidden bg-black"
>
  <div
    class={contentClasses}
    style={{
      fontFamily: "Barlow",
      textShadow:
        overlayVariant === "hero"
          ? "0 1px 16px rgba(0, 0, 0, 0.35)"
          : "0 0 40px rgba(0, 0, 0, 0.9)",
    }}
  >
    <slot />
  </div>

  <div class:list={["banner-overlay", overlayKind && `banner-overlay--${overlayKind}`]}>
    {video ? (
      <video
        src={video}
        autoplay
        muted
        loop
        playsinline
        class="w-full h-full object-cover absolute top-0 left-0"
      />
    ) : (
      <div class="banner-image-reveal absolute top-0 left-0 h-full w-full">
        <Image
          src={picture}
          alt=""
          width={1920}
          height={1080}
          class="w-full h-full object-cover"
        />
      </div>
    )}
  </div>

  {!video && (
    <div class="banner-reveal-veil absolute inset-0 z-10 bg-black pointer-events-none" />
  )}
</div>

<style>
  @keyframes banner-zoom {
    from {
      transform: scale(1.05);
    }
    to {
      transform: scale(1);
    }
  }

  @keyframes banner-veil-fade {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  .banner-image-reveal {
    animation: banner-zoom 1.5s ease both;
    transform-origin: center;
    will-change: transform;
  }

  /* Overlay du hero — voile sombre rendu via ::after.
     Sur mobile le hero fait 35vh, donc on adoucit le bas pour ne pas
     comprimer la zone sombre du dégradé. */
  .banner-overlay--default::after,
  .banner-overlay--hero-image::after,
  .banner-overlay--hero-video::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 20;
    pointer-events: none;
  }

  .banner-overlay--default::after {
    background: linear-gradient(
      180deg,
      transparent 0%,
      transparent 65%,
      rgb(0 0 0 / 0.4) 100%
    );
  }

  .banner-overlay--hero-image::after {
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgb(0 0 0 / 0.12) 55%,
      rgb(0 0 0 / 0.32) 100%
    );
  }

  .banner-overlay--hero-video::after {
    background: linear-gradient(
      180deg,
      rgb(0 0 0 / 0.22) 0%,
      rgb(0 0 0 / 0.08) 35%,
      rgb(0 0 0 / 0.05) 100%
    );
  }

  @media (min-width: 768px) {
    .banner-overlay--default::after {
      background: linear-gradient(
        180deg,
        transparent 0%,
        transparent 50%,
        rgb(0 0 0 / 0.7) 100%
      );
    }

    .banner-overlay--hero-image::after {
      background: linear-gradient(
        180deg,
        rgb(0 0 0 / 0) 0%,
        rgb(0 0 0 / 0.22) 40%,
        rgb(0 0 0 / 0.58) 100%
      );
    }

    .banner-overlay--hero-video::after {
      background: linear-gradient(
        180deg,
        rgb(0 0 0 / 0.22) 0%,
        rgb(0 0 0 / 0.1) 30%,
        rgb(0 0 0 / 0.08) 100%
      );
    }
  }

  .banner-reveal-veil {
    animation: banner-veil-fade 1.5s ease both;
  }

  @media (prefers-reduced-motion: reduce) {
    .banner-image-reveal,
    .banner-reveal-veil {
      animation: none;
    }
    .banner-reveal-veil {
      opacity: 0;
    }
  }
</style>
